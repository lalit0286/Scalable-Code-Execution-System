{
  "name": "code-execution-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --prefix-colors \"blue,green,magenta\" --names \"api,worker,web\" \"cd apps/api && npm run dev\" \"cd apps/worker && npm run dev\" \"cd apps/web && npm run dev\"",
    "predev": "npm run build --workspace=packages/shared",
    "postinstall": "npm run build --workspace=packages/shared",
    "lint": "npm run lint --workspaces",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down -v",
    "db:generate": "npm run db:generate --workspace=apps/api",
    "db:migrate": "npm run db:migrate --workspace=apps/api"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}